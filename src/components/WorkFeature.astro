---
const response = await globalThis.fetch(
  'https://api.github.com/users/olankens/repos?sort=updated&direction=desc&per_page=8'
);
const repos = await response.json();
const filteredRepos = repos.filter((repo: any) => !['olanpage', 'olankens'].includes(repo?.name));

const reposData = filteredRepos.slice(0, 6).map((repo: any) => ({
  header1: repo?.name || 'WORK',
  header2: repo?.language || 'RECENT COMMITS',
  content: repo?.description || 'Check out my latest GitHub repository!',
  pictureUrl: `https://raw.githubusercontent.com/${repo?.full_name}/main/.assets/social.png`,
  url: repo?.html_url || `https://github.com/${repo?.full_name}`,
}));

const initialRepo = reposData[0] || {
  header1: 'WORK',
  header2: 'RECENT COMMITS',
  content: 'Check out my latest GitHub repository!',
  pictureUrl: '',
  url: '#',
};
---

<section
  id="work-feature"
  class="w-full bg-linear-to-r from-violet-950 to-violet-950/90 text-center text-white sm:text-left"
>
  <div class="mx-auto grid max-w-4xl grid-cols-1 gap-12 p-12 sm:grid-cols-2">
    <!-- Title: Col 1 on Desktop -->
    <div class="flex flex-col gap-2 sm:col-start-1">
      <h1 class="repo-header1 text-3xl font-bold uppercase transition-opacity duration-300">
        {initialRepo.header1}
      </h1>
      <h2 class="repo-header2 text-xl font-light uppercase transition-opacity duration-300">
        {initialRepo.header2}
      </h2>
      <div class="mt-10 h-1 w-full overflow-hidden bg-white/30">
        <div class="repo-progress h-full w-0 bg-white" style="transition: width 0ms"></div>
      </div>
    </div>

    <!-- Image: Col 2, Row span 2 on Desktop -->
    <div class="flex items-center justify-center sm:col-start-2 sm:row-span-2">
      <a
        href={initialRepo.url}
        target="_blank"
        rel="noopener noreferrer"
        class="repo-link block w-full"
      >
        <img
          class="repo-image aspect-square h-auto w-full rounded-md border-2 border-white object-cover transition-opacity duration-300"
          src={initialRepo.pictureUrl}
          alt={initialRepo.header1}
          width="274"
          height="258"
        />
      </a>
    </div>

    <!-- Content Div: Col 1, Row 2 on Desktop -->
    <div
      class="repo-content self-end justify-self-end text-lg leading-relaxed transition-opacity duration-300 sm:col-start-1 sm:row-start-2 md:leading-loose"
    >
      {initialRepo.content}
    </div>
  </div>
  <script define:vars={{ reposData }}>
    if (reposData && reposData.length > 1) {
      // Prefetch all images so they appear smoothly without network delay
      reposData.forEach((repo) => {
        if (repo.pictureUrl) {
          const prefetchImg = new Image();
          prefetchImg.src = repo.pictureUrl;
        }
      });

      let currentIndex = 0;
      const section = document.getElementById('work-feature');

      if (section) {
        const header1El = section.querySelector('.repo-header1');
        const header2El = section.querySelector('.repo-header2');
        const imageEl = section.querySelector('.repo-image');
        const linkEl = section.querySelector('.repo-link');
        const contentEl = section.querySelector('.repo-content');
        const progressEl = section.querySelector('.repo-progress');

        if (progressEl) {
          progressEl.style.transition = 'none';
          progressEl.style.width = '0%';
          void progressEl.offsetWidth; // Force layout recalculation
          progressEl.style.transition = 'width 12000ms linear';
          progressEl.style.width = '100%';
        }

        setInterval(() => {
          if (progressEl) {
            progressEl.style.transition = 'none';
            progressEl.style.width = '0%';
            void progressEl.offsetWidth; // Force layout recalculation
            progressEl.style.transition = 'width 12000ms linear';
            progressEl.style.width = '100%';
          }

          currentIndex = (currentIndex + 1) % reposData.length;
          const repo = reposData[currentIndex];

          if (header1El && header2El && imageEl && contentEl) {
            // Fade out
            header1El.style.opacity = '0';
            header2El.style.opacity = '0';
            imageEl.style.opacity = '0';
            contentEl.style.opacity = '0';

            setTimeout(() => {
              // Update content
              header1El.textContent = repo.header1;
              header2El.textContent = repo.header2;
              imageEl.src = repo.pictureUrl;
              imageEl.alt = repo.header1;
              if (linkEl) linkEl.href = repo.url;
              contentEl.textContent = repo.content;

              // Fade in
              header1El.style.opacity = '1';
              header2El.style.opacity = '1';
              imageEl.style.opacity = '1';
              contentEl.style.opacity = '1';
            }, 250);
          }
        }, 12000);
      }
    }
  </script>
</section>
