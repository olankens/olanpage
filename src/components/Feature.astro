---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  header1: string;
  header2: string;
  content: string;
  picture: ImageMetadata;
}

const { header1, header2, content, picture } = Astro.props;
---

<section
  class="w-full bg-linear-to-r from-violet-950 to-violet-950/90 text-center text-white sm:text-left"
>
  <div class="mx-auto grid max-w-4xl grid-cols-1 gap-12 p-12 sm:grid-cols-2">
    <!-- Title: Col 1 on Desktop -->
    <div class="flex flex-col gap-2 sm:col-start-1">
      <h1 class="mt-[-8px] text-4xl font-bold uppercase">{header1}</h1>
      <h2 class="text-2xl font-light uppercase">{header2}</h2>
      <hr class="mt-10 w-full border-2 border-white" />
    </div>

    <!-- Image: Col 2, Row span 2 on Desktop -->
    <div class="flex items-center justify-center sm:col-start-2 sm:row-span-2">
      <Image src={picture} alt={header1} class="aspect-square h-auto w-full object-contain" />
    </div>

    <!-- Content Div: Col 1, Row 2 on Desktop -->
    <div
      class="mb-[-8px] self-end justify-self-end text-lg sm:col-start-1 sm:row-start-2 md:leading-loose"
    >
      {content}
    </div>
  </div>
</section>
