---
/* global fetch */
const GH_USER = 'olankens';
// @ts-ignore
const response = await fetch(
  `https://api.github.com/users/${GH_USER}/repos?sort=updated&per_page=10`
);
let repos = [];
if (response.ok) {
  repos = await response.json();
}

const projects = Array.isArray(repos)
  ? repos.map((repo: any) => ({
      name: repo.name,
      description: repo.description,
      url: repo.html_url,
      image: `https://raw.githubusercontent.com/${GH_USER}/${repo.name}/refs/heads/main/.assets/social.png`,
      fallbackImage: `https://github.com/${GH_USER}.png`,
    }))
  : [];

const N = projects.length;
const duration_s = N * 8;
const styleString = `
  <style>
    @keyframes carouselFade {
      0% { opacity: 0; z-index: 0; pointer-events: none; }
      ${(1 / Math.max(duration_s, 1)) * 100}% { opacity: 1; z-index: 10; pointer-events: auto; }
      ${(8 / Math.max(duration_s, 1)) * 100}% { opacity: 1; z-index: 10; pointer-events: auto; }
      ${(9 / Math.max(duration_s, 1)) * 100}% { opacity: 0; z-index: 0; pointer-events: none; }
      100% { opacity: 0; z-index: 0; pointer-events: none; }
    }
  </style>
`;
---

{N > 1 && <div style="display: contents;" set:html={styleString} />}

<div
  class="grid w-full max-w-sm overflow-hidden rounded-xl border border-white/20 bg-white/10 shadow-lg backdrop-blur-md"
>
  {
    N > 0 ? (
      projects.map((project, index) => {
        const isAnimated = N > 1;
        const animationStyle = isAnimated
          ? `animation: carouselFade ${duration_s}s infinite ease-in-out both; animation-delay: ${index * 8 - 1}s;`
          : `opacity: 1; z-index: 10; pointer-events: auto;`;

        return (
          <a
            href={project.url}
            target="_blank"
            rel="noopener noreferrer"
            class="col-start-1 row-start-1 flex flex-col focus:outline-hidden"
            style={animationStyle}
          >
            <div class="relative h-48 w-full overflow-hidden bg-black/20">
              <img
                src={project.image}
                alt={project.name}
                class="absolute inset-0 h-full w-full object-cover"
                onerror={`this.src='${project.fallbackImage}'; this.className='absolute inset-0 h-full w-full object-contain p-8 opacity-50'; this.onerror=null;`}
              />
            </div>
            <div class="flex flex-col gap-3 p-6 text-left">
              <h3 class="line-clamp-1 text-xl leading-tight font-bold text-white">
                {project.name}
              </h3>
              <p class="line-clamp-3 text-sm leading-relaxed text-white/80">
                {project.description || 'No description provided.'}
              </p>
            </div>
          </a>
        );
      })
    ) : (
      <div class="col-start-1 row-start-1 flex min-h-[22rem] items-center justify-center p-6 text-center text-white/80">
        Loading projects...
      </div>
    )
  }
</div>
