---
import '../styles/global.css';
import Feature from '../components/Feature.astro';
import FeatureReverse from '../components/FeatureReverse.astro';
import WorkFeature from '../components/WorkFeature.astro';

import Avatar from '../assets/avatar.png';
import Backend from '../assets/backend.png';
import Frontend from '../assets/frontend.svg';
import Mobile from '../assets/mobile.svg';
---

<html lang="en" class="overflow-y-auto overscroll-none">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Jolan Gerkens | Home</title>
  </head>
  <body class="flex min-h-dvh flex-col divide-y-3 divide-white">
    <Feature
      header1="Jolan Gerkens"
      header2="Software Developer"
      content="Building robust backend systems, intuitive frontend interfaces, and seamless mobile experiences. Specializing in full-stack development with a focus on scalable architecture and clean code."
      picture={Avatar}
    />
    <FeatureReverse
      header1="Backend"
      header2="Behind the scenes"
      content="Architecting robust server-side systems and APIs with Spring Boot. Specializing in database design, microservices architecture, and scalable infrastructure that delivers reliability and performance at any scale."
      picture={Backend}
    />
    <Feature
      header1="Frontend"
      header2="What users see"
      content="Building engaging digital experiences with Angular through clean code and thoughtful design implementation. Focused on responsive layouts, interactive components, and accessible interfaces that users love to interact with every day."
      picture={Frontend}
    />
    <FeatureReverse
      header1="Mobile"
      header2="Anywhere, anytime"
      content="Building cross-platform mobile applications that users carry everywhere. Specializing in Flutter development, intuitive touch interfaces, and optimized performance that delivers smooth experiences in your pocket."
      picture={Mobile}
    />
    <WorkFeature />
  </body>
</html>
